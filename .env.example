# Frontend/backend bridge
VITE_API_BASE_URL=http://localhost:8000

# Local backend server
GLAVRED_ENV=local
GLAVRED_API_HOST=127.0.0.1
GLAVRED_API_PORT=8000
GLAVRED_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5176,http://127.0.0.1:5176

# Persistence for the future backend slices
DATABASE_URL=postgresql+psycopg://glavred:glavred@localhost:5432/glavred
REDIS_URL=redis://localhost:6379/0
AI_RUN_AUDIT_DB_PATH=var/glavred-ai-runs.sqlite3
DRAFT_RUN_DB_PATH=var/glavred-draft-runs.sqlite3
DRAFT_REVISION_MAX_ITERATIONS=3
DRAFT_RUN_EXECUTION_MODE=standard
DRAFT_RESEARCH_BUDGET_OVERRIDES=
DRAFT_RUN_SMOKE_BUDGET_OVERRIDES=

# OpenRouter is the default LLM provider for the backend execution layer.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=deepseek/deepseek-v4-pro
OPENROUTER_BACKUP_MODEL=qwen/qwen3.7-plus
DRAFT_RESEARCH_MODEL=google/gemini-3.1-pro-preview
DRAFT_STRATEGY_MODEL=z-ai/glm-5.2
DRAFT_WRITER_MODEL=anthropic/claude-haiku-4.5
DRAFT_REVIEW_MODEL=openai/gpt-5.4-mini
DRAFT_CRITIC_MODEL=openai/gpt-4.1
DRAFT_ANOTHER_ANGLE_MODEL=qwen/qwen3.7-max
OPENROUTER_APP_NAME=Glavred
OPENROUTER_HTTP_REFERER=http://localhost:5173
OPENROUTER_WEB_TOOLS_ENABLED=false
OPENROUTER_WEB_SEARCH_MODEL=perplexity/sonar-pro
OPENROUTER_WEB_SEARCH_MAX_RESULTS=5

# langgraph-document-ai-platform integration boundary.
LANGGRAPH_DOCUMENT_AI_PLATFORM_MODE=local
LANGGRAPH_DOCUMENT_AI_PLATFORM_CONFIG=
